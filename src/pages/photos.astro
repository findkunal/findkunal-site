---
import BaseLayout from '../layouts/BaseLayout.astro';

const CLOUD_NAME = 'dbi1tlqg3';
const TAG = 'blog';

type CloudinaryResource = {
  public_id: string;
  format: string;
  version: number;
  width: number;
  height: number;
  created_at: string;
  context?: { custom?: { caption?: string; alt?: string } };
};

let resources: CloudinaryResource[] = [];
let fetchError: string | null = null;

try {
  const res = await fetch(
    `https://res.cloudinary.com/${CLOUD_NAME}/image/list/${TAG}.json`,
  );
  if (!res.ok) {
    throw new Error(`Cloudinary list returned ${res.status}`);
  }
  const data = (await res.json()) as { resources: CloudinaryResource[] };
  resources = (data.resources ?? []).sort(
    (a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime(),
  );
} catch (err) {
  fetchError = err instanceof Error ? err.message : 'Failed to load photos.';
  console.warn('[photos] Could not load Cloudinary list:', fetchError);
}

const cldUrl = (
  publicId: string,
  version: number,
  format: string,
  transforms: string,
) =>
  `https://res.cloudinary.com/${CLOUD_NAME}/image/upload/${transforms}/v${version}/${publicId}.${format}`;

const photos = resources.map((r) => ({
  id: r.public_id,
  caption: r.context?.custom?.caption ?? '',
  alt: r.context?.custom?.alt ?? r.context?.custom?.caption ?? r.public_id,
  thumb: cldUrl(r.public_id, r.version, r.format, 'f_auto,q_auto,c_fit,w_800,h_800'),
  large: cldUrl(r.public_id, r.version, r.format, 'f_auto,q_auto,c_limit,w_1800,h_1800'),
}));
---
<BaseLayout
  title="Photos — Kunal"
  description="A small gallery of photos I've taken."
>
  <div class="photos-head">
    <div>
      <h1>Photos</h1>
      <p class="lede">A few moments worth keeping.</p>
    </div>

    {photos.length > 0 && (
      <div class="view-toggle" role="tablist" aria-label="Gallery layout">
        <button type="button" data-view="grid-3" class="view-btn is-active" aria-label="3-column grid">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><rect x="2" y="2" width="6" height="6" rx="1"/><rect x="9" y="2" width="6" height="6" rx="1"/><rect x="16" y="2" width="6" height="6" rx="1"/><rect x="2" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/><rect x="16" y="9" width="6" height="6" rx="1"/><rect x="2" y="16" width="6" height="6" rx="1"/><rect x="9" y="16" width="6" height="6" rx="1"/><rect x="16" y="16" width="6" height="6" rx="1"/></svg>
        </button>
        <button type="button" data-view="grid-2" class="view-btn" aria-label="2-column grid">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><rect x="2" y="2" width="9" height="9" rx="1"/><rect x="13" y="2" width="9" height="9" rx="1"/><rect x="2" y="13" width="9" height="9" rx="1"/><rect x="13" y="13" width="9" height="9" rx="1"/></svg>
        </button>
        <button type="button" data-view="single" class="view-btn" aria-label="Single photo view">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="1.5"/></svg>
        </button>
      </div>
    )}
  </div>

  {fetchError && (
    <p class="muted">Couldn't load the gallery right now. Please check back later.</p>
  )}

  {!fetchError && photos.length === 0 && (
    <p class="muted">No photos yet — check back soon.</p>
  )}

  {photos.length > 0 && (
    <>
      <ul id="photo-grid" class="photo-grid clean cols-3">
        {photos.map((p, i) => (
          <li class="photo">
            <button type="button" class="photo-tile" data-index={i} aria-label={`View photo ${i + 1}`}>
              <img
                src={p.thumb}
                alt={p.alt}
                loading="lazy"
                decoding="async"
                width={800}
                height={800}
              />
              {p.caption && <span class="caption">{p.caption}</span>}
            </button>
          </li>
        ))}
      </ul>

      <div id="photo-single" class="single hidden" aria-hidden="true">
        <figure>
          <div class="single-frame">
            <div id="single-spinner" class="spinner" aria-hidden="true"></div>
            <img id="single-img" src="" alt="" />
          </div>
          <figcaption id="single-caption" class="muted"></figcaption>
        </figure>
        <div class="single-controls">
          <button type="button" id="prev-btn" class="nav-btn" aria-label="Previous photo">← Previous</button>
          <span id="single-counter" class="muted"></span>
          <button type="button" id="next-btn" class="nav-btn" aria-label="Next photo">Next →</button>
        </div>
      </div>
    </>
  )}
</BaseLayout>

<script is:inline define:vars={{ photos }}>
  (() => {
    if (!photos || photos.length === 0) return;

    const grid = document.getElementById('photo-grid');
    const single = document.getElementById('photo-single');
    const singleImg = document.getElementById('single-img');
    const singleCaption = document.getElementById('single-caption');
    const counter = document.getElementById('single-counter');
    const spinner = document.getElementById('single-spinner');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    const buttons = document.querySelectorAll('.view-btn');

    let currentIndex = 0;
    let loadToken = 0;

    const setLoading = (loading) => {
      spinner.classList.toggle('is-visible', loading);
      singleImg.classList.toggle('is-loading', loading);
      prevBtn.disabled = loading;
      nextBtn.disabled = loading;
    };

    const setView = (view) => {
      buttons.forEach((b) => b.classList.toggle('is-active', b.dataset.view === view));
      if (view === 'single') {
        grid.classList.add('hidden');
        single.classList.remove('hidden');
        single.setAttribute('aria-hidden', 'false');
        showSingle(currentIndex);
      } else {
        single.classList.add('hidden');
        single.setAttribute('aria-hidden', 'true');
        grid.classList.remove('hidden');
        grid.classList.remove('cols-2', 'cols-3');
        grid.classList.add(view === 'grid-2' ? 'cols-2' : 'cols-3');
      }
    };

    const showSingle = (i) => {
      currentIndex = (i + photos.length) % photos.length;
      const p = photos[currentIndex];
      const token = ++loadToken;
      setLoading(true);
      singleImg.alt = p.alt;
      singleCaption.textContent = p.caption || '';
      counter.textContent = `${currentIndex + 1} / ${photos.length}`;

      const preload = new Image();
      preload.onload = () => {
        if (token !== loadToken) return;
        singleImg.src = p.large;
        setLoading(false);
      };
      preload.onerror = () => {
        if (token !== loadToken) return;
        setLoading(false);
      };
      preload.src = p.large;
    };

    buttons.forEach((b) =>
      b.addEventListener('click', () => setView(b.dataset.view)),
    );

    grid.querySelectorAll('.photo-tile').forEach((tile) => {
      tile.addEventListener('click', () => {
        currentIndex = Number(tile.dataset.index) || 0;
        setView('single');
      });
    });

    prevBtn.addEventListener('click', () => showSingle(currentIndex - 1));
    nextBtn.addEventListener('click', () => showSingle(currentIndex + 1));

    document.addEventListener('keydown', (e) => {
      if (single.classList.contains('hidden')) return;
      if (e.key === 'ArrowLeft') showSingle(currentIndex - 1);
      else if (e.key === 'ArrowRight') showSingle(currentIndex + 1);
    });
  })();
</script>

<style>
  .lede { font-size: 1.1rem; color: var(--muted); margin-bottom: 0; }

  .photos-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .view-toggle {
    display: inline-flex;
    border: 1px solid var(--rule);
    border-radius: 8px;
    overflow: hidden;
  }
  .view-btn {
    background: transparent;
    border: none;
    color: var(--muted);
    padding: 0.5rem 0.7rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-right: 1px solid var(--rule);
    transition: color 0.15s ease, background 0.15s ease;
  }
  .view-btn:last-child { border-right: none; }
  .view-btn:hover { color: var(--ink); }
  .view-btn.is-active {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .photo-grid {
    display: grid;
    gap: 0.5rem;
  }
  .photo-grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
  .photo-grid.cols-2 { grid-template-columns: repeat(2, 1fr); }

  .photo-tile {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: var(--rule);
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
  }
  .photo-tile img {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: contain;
    background: var(--rule);
    transition: transform 0.3s ease, opacity 0.2s ease;
  }
  .photo-tile:hover img {
    transform: scale(1.03);
    opacity: 0.95;
  }
  .caption {
    display: block;
    padding: 0.4rem 0.5rem;
    font-size: 0.8rem;
    color: var(--muted);
    background: var(--bg);
    text-align: left;
  }

  .single figure {
    margin: 0;
  }
  .single-frame {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    background: #000;
    min-height: 240px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .single img {
    display: block;
    width: 100%;
    max-height: 80vh;
    object-fit: contain;
    transition: opacity 0.2s ease;
  }
  .single img.is-loading { opacity: 0; }
  .spinner {
    position: absolute;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 3px solid rgba(255, 255, 255, 0.2);
    border-top-color: var(--accent);
    animation: spin 0.8s linear infinite;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s ease;
  }
  .spinner.is-visible { opacity: 1; }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  .nav-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .nav-btn:disabled:hover {
    border-color: var(--rule);
    color: var(--ink);
  }
  .single figcaption {
    padding: 0.75rem 0.25rem 0;
    font-size: 0.95rem;
  }
  .single-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1rem;
  }
  .nav-btn {
    background: transparent;
    border: 1px solid var(--rule);
    border-radius: 6px;
    color: var(--ink);
    padding: 0.5rem 1rem;
    font: inherit;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .nav-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .hidden { display: none !important; }

  @media (max-width: 540px) {
    .photo-grid.cols-3 { grid-template-columns: repeat(2, 1fr); }
  }
</style>
