---
import BaseLayout from '../layouts/BaseLayout.astro';

const CLOUD_NAME = 'dbi1tlqg3';
const TAG = 'blog';
---
<BaseLayout
  title="Photos — Kunal"
  description="A small gallery of photos I've taken."
>
  <div class="photos-head">
    <div>
      <h1>Photos</h1>
      <p class="lede">A few moments worth keeping.</p>
    </div>

    <div id="view-toggle" class="view-toggle hidden" role="tablist" aria-label="Gallery layout">
      <button type="button" data-view="grid-3" class="view-btn is-active" aria-label="3-column grid">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><rect x="2" y="2" width="6" height="6" rx="1"/><rect x="9" y="2" width="6" height="6" rx="1"/><rect x="16" y="2" width="6" height="6" rx="1"/><rect x="2" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/><rect x="16" y="9" width="6" height="6" rx="1"/><rect x="2" y="16" width="6" height="6" rx="1"/><rect x="9" y="16" width="6" height="6" rx="1"/><rect x="16" y="16" width="6" height="6" rx="1"/></svg>
      </button>
      <button type="button" data-view="grid-2" class="view-btn" aria-label="2-column grid">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><rect x="2" y="2" width="9" height="9" rx="1"/><rect x="13" y="2" width="9" height="9" rx="1"/><rect x="2" y="13" width="9" height="9" rx="1"/><rect x="13" y="13" width="9" height="9" rx="1"/></svg>
      </button>
      <button type="button" data-view="single" class="view-btn" aria-label="Single photo view">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="1.5"/></svg>
      </button>
    </div>
  </div>

  <p id="photos-status" class="muted">Loading photos…</p>

  <ul id="photo-grid" class="photo-grid clean cols-3 hidden"></ul>

  <div id="photo-single" class="single hidden" aria-hidden="true">
    <figure>
      <div class="single-frame">
        <div id="single-spinner" class="spinner" aria-hidden="true"></div>
        <img id="single-img" src="" alt="" />
      </div>
      <figcaption id="single-caption" class="muted"></figcaption>
    </figure>
    <div class="single-controls">
      <button type="button" id="prev-btn" class="nav-btn" aria-label="Previous photo">← Previous</button>
      <span id="single-counter" class="muted"></span>
      <button type="button" id="next-btn" class="nav-btn" aria-label="Next photo">Next →</button>
    </div>
  </div>
</BaseLayout>

<script is:inline define:vars={{ CLOUD_NAME, TAG }}>
  (async () => {
    const status = document.getElementById('photos-status');
    const grid = document.getElementById('photo-grid');
    const toggle = document.getElementById('view-toggle');
    const single = document.getElementById('photo-single');
    const singleImg = document.getElementById('single-img');
    const singleCaption = document.getElementById('single-caption');
    const counter = document.getElementById('single-counter');
    const spinner = document.getElementById('single-spinner');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');

    const cldUrl = (publicId, version, format, transforms) =>
      `https://res.cloudinary.com/${CLOUD_NAME}/image/upload/${transforms}/v${version}/${publicId}.${format}`;

    let photos = [];
    try {
      const res = await fetch(
        `https://res.cloudinary.com/${CLOUD_NAME}/image/list/${TAG}.json`,
        { cache: 'no-store' },
      );
      if (!res.ok) throw new Error(`Cloudinary list returned ${res.status}`);
      const data = await res.json();
      const resources = (data.resources ?? []).sort(
        (a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime(),
      );
      photos = resources.map((r) => ({
        id: r.public_id,
        caption: r.context?.custom?.caption ?? '',
        alt: r.context?.custom?.alt ?? r.context?.custom?.caption ?? r.public_id,
        thumb: cldUrl(r.public_id, r.version, r.format, 'f_auto,q_auto,c_fit,w_800,h_800'),
        large: cldUrl(r.public_id, r.version, r.format, 'f_auto,q_auto,c_limit,w_1800,h_1800'),
      }));
    } catch (err) {
      console.warn('[photos] Could not load Cloudinary list:', err);
      status.textContent = "Couldn't load the gallery right now. Please check back later.";
      return;
    }

    if (photos.length === 0) {
      status.textContent = 'No photos yet — check back soon.';
      return;
    }

    // Render grid
    const frag = document.createDocumentFragment();
    photos.forEach((p, i) => {
      const li = document.createElement('li');
      li.className = 'photo';
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'photo-tile';
      btn.dataset.index = String(i);
      btn.setAttribute('aria-label', `View photo ${i + 1}`);
      const img = document.createElement('img');
      img.src = p.thumb;
      img.alt = p.alt;
      img.loading = 'lazy';
      img.decoding = 'async';
      img.width = 800;
      img.height = 800;
      btn.appendChild(img);
      if (p.caption) {
        const span = document.createElement('span');
        span.className = 'caption';
        span.textContent = p.caption;
        btn.appendChild(span);
      }
      li.appendChild(btn);
      frag.appendChild(li);
    });
    grid.appendChild(frag);
    status.classList.add('hidden');
    grid.classList.remove('hidden');
    toggle.classList.remove('hidden');

    const buttons = toggle.querySelectorAll('.view-btn');
    let currentIndex = 0;
    let loadToken = 0;

    const setLoading = (loading) => {
      spinner.classList.toggle('is-visible', loading);
      singleImg.classList.toggle('is-loading', loading);
      prevBtn.disabled = loading;
      nextBtn.disabled = loading;
    };

    const setView = (view) => {
      buttons.forEach((b) => b.classList.toggle('is-active', b.dataset.view === view));
      if (view === 'single') {
        grid.classList.add('hidden');
        single.classList.remove('hidden');
        single.setAttribute('aria-hidden', 'false');
        showSingle(currentIndex);
      } else {
        single.classList.add('hidden');
        single.setAttribute('aria-hidden', 'true');
        grid.classList.remove('hidden');
        grid.classList.remove('cols-2', 'cols-3');
        grid.classList.add(view === 'grid-2' ? 'cols-2' : 'cols-3');
      }
    };

    const showSingle = (i) => {
      currentIndex = (i + photos.length) % photos.length;
      const p = photos[currentIndex];
      const token = ++loadToken;
      setLoading(true);
      singleImg.alt = p.alt;
      singleCaption.textContent = p.caption || '';
      counter.textContent = `${currentIndex + 1} / ${photos.length}`;

      const preload = new Image();
      preload.onload = () => {
        if (token !== loadToken) return;
        singleImg.src = p.large;
        setLoading(false);
      };
      preload.onerror = () => {
        if (token !== loadToken) return;
        setLoading(false);
      };
      preload.src = p.large;
    };

    buttons.forEach((b) =>
      b.addEventListener('click', () => setView(b.dataset.view)),
    );

    grid.querySelectorAll('.photo-tile').forEach((tile) => {
      tile.addEventListener('click', () => {
        currentIndex = Number(tile.dataset.index) || 0;
        setView('single');
      });
    });

    prevBtn.addEventListener('click', () => showSingle(currentIndex - 1));
    nextBtn.addEventListener('click', () => showSingle(currentIndex + 1));

    document.addEventListener('keydown', (e) => {
      if (single.classList.contains('hidden')) return;
      if (e.key === 'ArrowLeft') showSingle(currentIndex - 1);
      else if (e.key === 'ArrowRight') showSingle(currentIndex + 1);
    });

    // Swipe support
    const frame = single.querySelector('.single-frame');
    let touchStartX = 0;
    let touchStartY = 0;
    let touchActive = false;
    frame.addEventListener('touchstart', (e) => {
      if (e.touches.length !== 1) return;
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      touchActive = true;
    }, { passive: true });
    frame.addEventListener('touchend', (e) => {
      if (!touchActive) return;
      touchActive = false;
      const t = e.changedTouches[0];
      const dx = t.clientX - touchStartX;
      const dy = t.clientY - touchStartY;
      if (Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy) * 1.2) {
        if (prevBtn.disabled || nextBtn.disabled) return;
        if (dx < 0) showSingle(currentIndex + 1);
        else showSingle(currentIndex - 1);
      }
    });
  })();
</script>

<style>
  .lede { font-size: 1.1rem; color: var(--muted); margin-bottom: 0; }

  .photos-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .view-toggle {
    display: inline-flex;
    border: 1px solid var(--rule);
    border-radius: 8px;
    overflow: hidden;
  }
  .view-btn {
    background: transparent;
    border: none;
    color: var(--muted);
    padding: 0.5rem 0.7rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-right: 1px solid var(--rule);
    transition: color 0.15s ease, background 0.15s ease;
  }
  .view-btn:last-child { border-right: none; }
  .view-btn:hover { color: var(--ink); }
  .view-btn.is-active {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }

  .photo-grid {
    column-gap: 0.5rem;
    margin: 0;
    padding: 0;
  }
  .photo-grid.cols-3 { column-count: 3; }
  .photo-grid.cols-2 { column-count: 2; }
  .photo-grid .photo {
    break-inside: avoid;
    margin-bottom: 0.5rem;
  }

  .photo-tile {
    display: block;
    width: 100%;
    padding: 0;
    border: none;
    background: transparent;
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
  }
  .photo-tile img {
    display: block;
    width: 100%;
    height: auto;
    transition: transform 0.3s ease, opacity 0.2s ease;
  }
  .photo-tile:hover img {
    transform: scale(1.03);
    opacity: 0.95;
  }
  .caption {
    display: block;
    padding: 0.4rem 0.1rem 0;
    font-size: 0.8rem;
    color: var(--muted);
    text-align: left;
  }

  .single figure {
    margin: 0;
  }
  .single-frame {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    background: #000;
    height: 70vh;
    min-height: 320px;
    display: flex;
    align-items: center;
    justify-content: center;
    touch-action: pan-y;
    user-select: none;
  }
  .single img {
    display: block;
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    transition: opacity 0.2s ease;
  }
  .single img.is-loading { opacity: 0; }
  .spinner {
    position: absolute;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 3px solid rgba(255, 255, 255, 0.2);
    border-top-color: var(--accent);
    animation: spin 0.8s linear infinite;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s ease;
  }
  .spinner.is-visible { opacity: 1; }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  .nav-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .nav-btn:disabled:hover {
    border-color: var(--rule);
    color: var(--ink);
  }
  .single figcaption {
    padding: 0.75rem 0.25rem 0;
    font-size: 0.95rem;
  }
  .single-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1rem;
  }
  .nav-btn {
    background: transparent;
    border: 1px solid var(--rule);
    border-radius: 6px;
    color: var(--ink);
    padding: 0.5rem 1rem;
    font: inherit;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .nav-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .hidden { display: none !important; }

  @media (max-width: 540px) {
    .photo-grid.cols-3 { column-count: 2; }
  }
</style>
