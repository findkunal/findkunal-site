---
// import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
// import AppCard from '../components/AppCard.astro';
import RecentPosts from '../components/RecentPosts.astro';

// Apps section hidden until workplace permission is granted.
// const apps = (await getCollection('apps')).sort((a, b) => a.data.order - b.data.order).slice(0, 4);
---
<BaseLayout title="Kunal — findkunal.com">
  <section class="hero">
    <p class="kicker">Builder · Learner · Stoic-in-progress</p>
    <h1>Hi, I'm Kunal.</h1>
    <p class="lede">
      I build IT solutions for real-world business problems, the kind that look
      small until you live with them. Outside of work, I'm drawn to philosophy,
      psychology, and the slow practice of mindfulness, with a soft spot for
      Stoicism whenever life asks me to grow up a little more. I love cooking,
      long conversations, and arguing both sides of a position just to see which
      one holds. I'm working on becoming a better leader, helping the people
      around me become better versions of themselves, and staying curious enough
      to keep learning. This site is where I write what I'm chewing on.
    </p>
  </section>

  <hr />

  {/*
    Apps section hidden until workplace permission is granted.
  <section>
    <h2>Apps</h2>
    {apps.length > 0 ? (
      <div class="grid">
        {apps.map((app) => (
          <AppCard
            href={`/apps/${app.id}`}
            name={app.data.name}
            tagline={app.data.tagline}
            status={app.data.status}
          />
        ))}
      </div>
    ) : (
      <p class="muted">App showcases coming soon.</p>
    )}
    <p style="margin-top:1rem;"><a href="/apps">All apps →</a></p>
  </section>

  <hr />
  */}

  <section>
    <h2>Recent writing</h2>
    <RecentPosts />
    <p style="margin-top:1rem;"><a href="https://thoughts.findkunal.com">All essays →</a></p>
  </section>
</BaseLayout>

<style>
  .hero { padding-top: 1rem; }
  .lede { font-size: 1.1rem; color: var(--muted); max-width: 38rem; }
</style>
