---
// import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
// import AppCard from '../components/AppCard.astro';
import RecentPosts from '../components/RecentPosts.astro';

// Apps section hidden until workplace permission is granted.
// const apps = (await getCollection('apps')).sort((a, b) => a.data.order - b.data.order).slice(0, 4);
---
<BaseLayout title="Kunal — findkunal.com">
  <section class="hero">
    <p class="kicker">Programmer · Stoic-in-Progress · Lifelong learner</p>
    <h1>Hi, I'm Kunal.</h1>
    <p class="lede">
      I build IT solutions for real-world business problems — and chase
      philosophy, Stoicism, and good conversations the rest of the time.
      This site is where I write what I'm chewing on.
    </p>
    <p class="more"><a href="/about">More about me →</a></p>
  </section>

  <hr />

  {/*
    Apps section hidden until workplace permission is granted.
  <section>
    <h2>Apps</h2>
    {apps.length > 0 ? (
      <div class="grid">
        {apps.map((app) => (
          <AppCard
            href={`/apps/${app.id}`}
            name={app.data.name}
            tagline={app.data.tagline}
            status={app.data.status}
          />
        ))}
      </div>
    ) : (
      <p class="muted">App showcases coming soon.</p>
    )}
    <p style="margin-top:1rem;"><a href="/apps">All apps →</a></p>
  </section>

  <hr />
  */}

  <section>
    <h2>Recent writing</h2>
    <RecentPosts />
    <p style="margin-top:1rem;"><a href="https://thoughts.findkunal.com">All essays →</a></p>
  </section>
</BaseLayout>

<style>
  .hero { padding-top: 1rem; }
  .lede { font-size: 1.1rem; color: var(--muted); max-width: 38rem; }
  .more { margin-top: 0.25rem; font-size: 0.95rem; }
</style>
