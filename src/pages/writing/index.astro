---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<BaseLayout title="Writing — Kunal" description="Essays and ideas I keep coming back to.">
  <h1>Writing</h1>
  <p class="lede">Essays on the things I find myself thinking about.</p>

  <ul class="clean posts">
    {posts.map((post) => (
      <li class="post">
        <a class="post-title" href={`/writing/${post.id}`}>{post.data.title}</a>
        {post.data.description && <p class="post-desc muted">{post.data.description}</p>}
        <p class="post-date muted">{formatDate(post.data.date)}</p>
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  .lede { font-size: 1.1rem; color: var(--muted); margin-bottom: 2.5rem; }
  .posts { display: flex; flex-direction: column; gap: 2rem; }
  .post { border-bottom: 1px solid var(--rule); padding-bottom: 2rem; }
  .post:last-child { border-bottom: none; }
  .post-title {
    font-size: 1.25rem;
    font-family: var(--font-serif);
    color: var(--ink);
    text-decoration: none;
    display: block;
    margin-bottom: 0.35rem;
  }
  .post-title:hover { color: var(--accent); }
  .post-desc { font-size: 0.95rem; margin: 0 0 0.4rem; line-height: 1.5; }
  .post-date { font-size: 0.82rem; margin: 0; }
</style>
