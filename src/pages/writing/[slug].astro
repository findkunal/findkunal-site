---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<BaseLayout title={`${post.data.title} — Kunal`} description={post.data.description}>
  <a class="back" href="/writing">← Writing</a>

  <article class="post">
    <header class="post-header">
      <h1>{post.data.title}</h1>
      {post.data.description && <p class="subtitle">{post.data.description}</p>}
      <p class="date muted">{formatDate(post.data.date)}</p>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .back {
    display: inline-flex;
    align-items: center;
    font-size: 0.9rem;
    color: var(--muted);
    text-decoration: none;
    margin-bottom: 2rem;
  }
  .back:hover { color: var(--ink); }

  .post { max-width: 40rem; }

  .post-header { margin-bottom: 2.5rem; }
  h1 { font-size: 2rem; line-height: 1.2; margin: 0 0 0.6rem; }
  .subtitle {
    font-size: 1.05rem;
    color: var(--muted);
    font-style: italic;
    margin: 0 0 0.75rem;
    line-height: 1.5;
  }
  .date { font-size: 0.85rem; margin: 0; }

  /* Prose */
  .prose { font-family: var(--font-serif); font-size: 1.125rem; line-height: 1.75; color: var(--ink); }
  .prose :global(p) { margin: 0 0 1.4rem; }
  .prose :global(h2) {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 600;
    margin: 2.5rem 0 0.75rem;
    color: var(--ink);
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 2.5rem 0;
  }
  .prose :global(em) { font-style: italic; }
  .prose :global(strong) { font-weight: 600; }
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--muted);
  }
</style>
