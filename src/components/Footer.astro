---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="inner">
    <span class="muted">© {year} Kunal</span>
    <span class="links">
      <a href="https://thoughts.findkunal.com/en/">Writing</a>
      <a href="https://x.com/findkunal" rel="me noopener">X</a>
      <a href="https://github.com/findkunal" rel="me noopener">GitHub</a>
      <a href="/colophon">Colophon</a>
      <a href="/sitemap-index.xml">Sitemap</a>
      <a href="/privacy">Privacy</a>
    </span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--rule);
  }
  .inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 1.25rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.9rem;
  }
  .links { display: flex; gap: 1rem; }
  .links a { color: var(--muted); text-decoration: none; }
  .links a:hover { color: var(--ink); }
</style>
