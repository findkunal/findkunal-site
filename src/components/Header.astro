---
const path = Astro.url.pathname;
const isActive = (p: string) => path === p || path.startsWith(p + '/');
const links = [
  { href: '/about', label: 'About' },
  // { href: '/apps', label: 'Apps' }, // hidden until workplace approval
  { href: 'https://thoughts.findkunal.com/en/', label: 'Writing', external: true },
  { href: '/photos', label: 'Photos' },
  { href: '/bookshelf', label: 'Bookshelf' },
  { href: '/favorites', label: 'Favorites' },
  { href: '/quotes', label: 'Quotes' },
  { href: '/contact', label: 'Contact' },
];
---
<header class="site-header">
  <div class="inner">
    <a class="brand" href="/" aria-label="Home">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 11.5 12 4l9 7.5"/>
        <path d="M5 10v9a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1v-9"/>
      </svg>
    </a>

    <nav class="desktop-nav" aria-label="Primary">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={['nav-link', { active: !l.external && isActive(l.href) }]}
          {...l.external ? { rel: 'noopener', target: '_self' } : {}}
        >{l.label}</a>
      ))}
    </nav>

    <button class="burger" id="nav-toggle" type="button"
      aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor"
        stroke-width="1.75" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6"  x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>

  <nav id="mobile-menu" class="mobile-nav" aria-label="Primary">
    {links.map((l) => (
      <a
        href={l.href}
        class:list={['mobile-link', { active: !l.external && isActive(l.href) }]}
        {...l.external ? { rel: 'noopener', target: '_self' } : {}}
      >{l.label}</a>
    ))}
  </nav>
</header>

<script is:inline>
  (function () {
    var toggle = document.getElementById('nav-toggle');
    var menu   = document.getElementById('mobile-menu');
    if (!toggle || !menu) return;

    function open() {
      menu.classList.add('is-open');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Close menu');
    }
    function close() {
      menu.classList.remove('is-open');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open menu');
    }

    toggle.addEventListener('click', function () {
      menu.classList.contains('is-open') ? close() : open();
    });

    menu.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', close);
    });

    document.addEventListener('click', function (e) {
      if (menu.classList.contains('is-open') &&
          !menu.contains(e.target) && !toggle.contains(e.target)) {
        close();
      }
    });
  })();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--rule);
  }

  .inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  /* Brand */
  .brand {
    display: inline-flex;
    align-items: center;
    color: var(--ink);
    text-decoration: none;
    padding: 0.25rem;
    border-radius: 6px;
    flex-shrink: 0;
    transition: color 0.15s;
  }
  .brand:hover { color: var(--accent); }

  /* Desktop nav */
  .desktop-nav {
    display: flex;
    gap: 1.1rem;
    flex-wrap: wrap;
  }
  .nav-link {
    text-decoration: none;
    color: var(--muted);
    font-size: 0.95rem;
    transition: color 0.15s;
  }
  .nav-link:hover,
  .nav-link.active { color: var(--ink); }

  /* Burger — hidden on wide screens */
  .burger {
    display: none;
    background: transparent;
    border: none;
    color: var(--ink);
    padding: 0.25rem;
    cursor: pointer;
    border-radius: 6px;
    flex-shrink: 0;
    transition: color 0.15s;
  }
  .burger:hover { color: var(--accent); }

  /* Mobile drawer — hidden until .is-open */
  .mobile-nav {
    display: none;
    flex-direction: column;
    border-top: 1px solid var(--rule);
    padding: 0.5rem 1.25rem 1rem;
  }
  .mobile-nav.is-open { display: flex; }

  .mobile-link {
    text-decoration: none;
    color: var(--muted);
    font-size: 1rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--rule);
    transition: color 0.15s;
  }
  .mobile-link:last-child { border-bottom: none; }
  .mobile-link:hover,
  .mobile-link.active { color: var(--ink); }

  /* Swap nav ↔ burger below 600 px */
  @media (max-width: 600px) {
    .desktop-nav { display: none; }
    .burger      { display: inline-flex; }
  }
</style>
