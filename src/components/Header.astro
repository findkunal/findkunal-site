---
const path = Astro.url.pathname;
const isActive = (p: string) => path === p || path.startsWith(p + '/');
const links = [
  { href: '/about', label: 'About' },
  // { href: '/apps', label: 'Apps' }, // hidden until workplace approval
  { href: 'https://thoughts.findkunal.com/en/', label: 'Writing', external: true },
  { href: '/photos', label: 'Photos' },
  { href: '/bookshelf', label: 'Bookshelf' },
  { href: '/favorites', label: 'Favorites' },
  { href: '/quotes', label: 'Quotes' },
  { href: '/contact', label: 'Contact' },
];
---
<header class="site-header">
  <div class="inner">
    <a class="brand" href="/" aria-label="Home">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M3 11.5 12 4l9 7.5"/>
        <path d="M5 10v9a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1v-9"/>
      </svg>
    </a>
    <nav>
      {links.map((l) => (
        <a
          href={l.href}
          class:list={['nav-link', { active: !l.external && isActive(l.href) }]}
          {...l.external ? { rel: 'noopener', target: '_self' } : {}}
        >{l.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
    background: var(--bg);
  }
  .inner {
    max-width: var(--max);
    margin: 0 auto;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--ink);
    text-decoration: none;
    padding: 0.25rem;
    border-radius: 6px;
    transition: color 0.15s ease;
  }
  .brand:hover { color: var(--accent); }
  nav {
    display: flex;
    gap: 1.1rem;
    flex-wrap: wrap;
  }
  .nav-link {
    text-decoration: none;
    color: var(--muted);
    font-size: 0.95rem;
  }
  .nav-link:hover { color: var(--ink); }
  .nav-link.active { color: var(--ink); }
</style>
